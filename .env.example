# Copy this file to `.env` and fill in real values.
# `.env` itself is gitignored; never commit real credentials.

# Optional base URL used by both Playwright (use.baseURL) and Cypress (e2e.baseUrl).
BASE_URL=https://demo.playwright.dev/todomvc

# Didaxis Studio test environment credentials (DS-1 tests).
# Required by tests/ds1-create-program.spec.ts and cypress/e2e/ds1-create-program.cy.js.
DIDAXIS_EMAIL=
DIDAXIS_PASSWORD=
