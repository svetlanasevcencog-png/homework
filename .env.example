# Copy to `.env` and fill in real values:
#   cp .env.example .env
# `.env` is gitignored — never commit real credentials.
# This file must contain placeholders only (no real secrets).

# =============================================================================
# Run tests — required to clone and run Playwright (`npx playwright test`)
# =============================================================================

# Didaxis test host (omit to use the default in fixtures/didaxis-url.js).
DIDAXIS_URL=https://test.didaxis.studio

# Primary account used by auth.setup.ts → storageState for chromium-didaxis.
DIDAXIS_EMAIL=you@example.com

# Password for DIDAXIS_EMAIL (never commit the real value).
DIDAXIS_PASSWORD=replace-me

# Bearer token for programs API create/teardown (trackProgram / api-cleanup).
DIDAXIS_API_TOKEN=replace-me-api-token

# Optional: second account for permission / role probes (read-only or limited user).
DIDAXIS_ALT_EMAIL=alt@example.com
DIDAXIS_ALT_PASSWORD=replace-me-alt

# TodoMVC demo base URL (example / todomvc specs only — not required for Didaxis).
BASE_URL=https://demo.playwright.dev/todomvc

# =============================================================================
# Agent / CI setup — not needed for `npx playwright test` alone
# =============================================================================

# Cursor API key for headless cursor-agent in CI
# (see .github/workflows/qa-orchestrator.yml; also used if you add test-generation.yml).
CURSOR_API_KEY=replace-me-cursor-api-key

# Atlassian / Jira — for Atlassian MCP in Cursor settings (local agents).
# Headless CI may use the same values as JIRA_* GitHub secrets.
ATLASSIAN_BASE_URL=https://your-domain.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace-me-atlassian-api-token
