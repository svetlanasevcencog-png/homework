# Copy this file to `.env` and fill in real values.
# `.env` itself is gitignored; never commit real credentials.

# TodoMVC demo (Playwright example/todomvc specs, Cypress todomvc).
BASE_URL=https://demo.playwright.dev/todomvc

# Didaxis Studio — shared by Playwright (DS-1–DS-5) and Cypress Didaxis specs.
# Optional: omit to use the default test host in fixtures/didaxis-url.js
DIDAXIS_URL=
DIDAXIS_EMAIL=
DIDAXIS_PASSWORD=
DIDAXIS_API_TOKEN=
